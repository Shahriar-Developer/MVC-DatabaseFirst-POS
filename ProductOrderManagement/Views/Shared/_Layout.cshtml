<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Shariar's Cafe</title>

    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --cafe-dark: #2c1810;
            --cafe-brown: #5d4037;
            --cafe-light: #a1887f;
            --cafe-cream: #f5f1ed;
            --accent-gold: #d4a574;
            --accent-orange: #e8956f;
        }

        * {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #fafaf8;
        }

        /* Navbar Styles */
        .navbar-cafe {
            background: linear-gradient(135deg, var(--cafe-dark) 0%, var(--cafe-brown) 100%);
            padding: 1rem 0;
            box-shadow: 0 2px 15px rgba(0, 0, 0, 0.15);
            position: relative;
            overflow: hidden;
        }

        .navbar-cafe::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: repeating-linear-gradient(
                90deg,
                transparent,
                transparent 2px,
                rgba(212, 165, 116, 0.03) 2px,
                rgba(212, 165, 116, 0.03) 4px
            );
            pointer-events: none;
        }

        .navbar-cafe .navbar-brand {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--accent-gold) !important;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.3s ease;
        }

        .navbar-cafe .navbar-brand:hover {
            transform: scale(1.05);
            text-shadow: 0 0 10px rgba(212, 165, 116, 0.5);
        }

        .navbar-cafe .navbar-brand i {
            font-size: 2rem;
            color: var(--accent-orange);
        }

        .navbar-cafe .nav-link {
            color: rgba(245, 241, 237, 0.85) !important;
            font-weight: 500;
            margin: 0 8px;
            position: relative;
            transition: all 0.3s ease;
            letter-spacing: 0.3px;
        }

        .navbar-cafe .nav-link:after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--accent-gold);
            transition: width 0.3s ease;
        }

        .navbar-cafe .nav-link:hover {
            color: var(--accent-gold) !important;
        }

        .navbar-cafe .nav-link:hover:after {
            width: 100%;
        }

        .navbar-cafe .btn-order {
            background: linear-gradient(135deg, var(--accent-orange) 0%, #d97753 100%);
            color: white !important;
            border: none;
            padding: 10px 25px;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(232, 149, 111, 0.3);
            margin-left: 10px;
        }

        .navbar-cafe .btn-order:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(232, 149, 111, 0.5);
            color: white;
        }

        .navbar-toggler {
            border: none;
            color: var(--accent-gold) !important;
        }

        .navbar-toggler:focus {
            outline: none;
            box-shadow: none;
        }

        /* Footer Styles */
        footer {
            background: linear-gradient(135deg, var(--cafe-dark) 0%, var(--cafe-brown) 100%);
            color: var(--accent-gold);
            padding: 30px 0;
            margin-top: 60px;
            text-align: center;
            border-top: 3px solid var(--accent-gold);
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        footer p {
            margin: 0;
        }

        /* Body Content */
        .body-content {
            padding: 20px 0;
            min-height: calc(100vh - 300px);
        }

        /* Scrollbar Styling */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: var(--cafe-cream);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--accent-gold);
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--cafe-brown);
        }
    </style>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-cafe">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="fas fa-coffee"></i> Shariar's Cafe
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item">
                        @Html.ActionLink("Home", "Index", "Home", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Categories", "Index", "ProductCategory", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Products", "Index", "Product", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Orders", "Index", "Order", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Place Order", "Create", "Order", null, new { @class = "nav-link btn btn-order" })
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
    </div>

    <footer>
        <p>&copy; @DateTime.Now.Year - Shariar's Cafe | Coffee Management System</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>


    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
