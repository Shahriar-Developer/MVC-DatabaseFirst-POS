@{
    ViewBag.Title = "Dashboard - Shariar's Cafe";
}

<style>
    :root {
        --cafe-dark: #2c1810;
        --cafe-brown: #5d4037;
        --cafe-light: #a1887f;
        --cafe-cream: #f5f1ed;
        --accent-gold: #d4a574;
        --accent-orange: #e8956f;
    }

    .hero-section {
        background: linear-gradient(135deg, var(--cafe-dark) 0%, var(--cafe-brown) 50%, var(--accent-orange) 100%);
        color: white;
        padding: 80px 0;
        margin-bottom: 50px;
        border-radius: 15px;
        box-shadow: 0 8px 30px rgba(44, 24, 16, 0.3);
        position: relative;
        overflow: hidden;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        font-size: 400px;
        opacity: 0.05;
        right: -50px;
        top: -50px;
        transform: rotate(-15deg);
    }

    .hero-section h1 {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 20px;
        letter-spacing: -1px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .hero-section p {
        font-size: 1.2rem;
        margin-bottom: 30px;
        opacity: 0.98;
        font-weight: 400;
    }

    .stat-card {
        background: white;
        border-radius: 15px;
        padding: 35px;
        margin-bottom: 30px;
        box-shadow: 0 5px 20px rgba(93, 64, 55, 0.1);
        transition: all 0.4s ease;
        border: 2px solid transparent;
        position: relative;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        border-radius: 15px 15px 0 0;
    }

    .stat-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 35px rgba(93, 64, 55, 0.2);
    }

    .stat-card .stat-number {
        font-size: 2.8rem;
        font-weight: 800;
        margin: 15px 0;
        letter-spacing: -1px;
    }

    .stat-card .stat-label {
        color: var(--cafe-brown);
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .stat-card.products::before {
        background: linear-gradient(90deg, var(--accent-gold) 0%, var(--accent-orange) 100%);
    }

    .stat-card.products .stat-number {
        color: var(--accent-orange);
    }

    .stat-card.orders::before {
        background: linear-gradient(90deg, #8b6f47 0%, var(--cafe-brown) 100%);
    }

    .stat-card.orders .stat-number {
        color: var(--cafe-brown);
    }

    .stat-card.categories::before {
        background: linear-gradient(90deg, var(--accent-gold) 0%, #c99463 100%);
    }

    .stat-card.categories .stat-number {
        color: var(--accent-gold);
    }

    .feature-section {
        margin-top: 70px;
        margin-bottom: 50px;
    }

    .feature-card {
        background: white;
        border-radius: 15px;
        padding: 45px 30px;
        text-align: center;
        margin-bottom: 30px;
        box-shadow: 0 5px 20px rgba(93, 64, 55, 0.08);
        transition: all 0.4s ease;
        height: 100%;
        border: 2px solid var(--cafe-cream);
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(232, 149, 111, 0.2);
        border-color: var(--accent-gold);
    }

    .feature-icon {
        font-size: 3.5rem;
        margin-bottom: 20px;
        display: inline-block;
        width: 80px;
        height: 80px;
        line-height: 80px;
        background: linear-gradient(135deg, var(--cafe-light) 0%, var(--accent-gold) 100%);
        border-radius: 50%;
        color: white;
    }

    .feature-card h3 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 15px;
        color: var(--cafe-dark);
        letter-spacing: -0.5px;
    }

    .feature-card p {
        color: #666;
        font-size: 0.95rem;
        line-height: 1.7;
    }

    .btn-group-custom {
        margin-top: 20px;
    }

    .btn-custom {
        padding: 14px 35px;
        font-weight: 700;
        border-radius: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
        letter-spacing: 0.5px;
        border: none;
    }

    .btn-custom-primary {
        background: linear-gradient(135deg, var(--accent-orange) 0%, #d97753 100%);
        color: white !important;
        box-shadow: 0 6px 20px rgba(232, 149, 111, 0.4);
    }

    .btn-custom-primary:hover {
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(232, 149, 111, 0.6);
    }

    .section-title {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 50px;
        color: var(--cafe-dark);
        position: relative;
        padding-bottom: 20px;
        letter-spacing: -0.5px;
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 80px;
        height: 5px;
        background: linear-gradient(90deg, var(--accent-gold) 0%, var(--accent-orange) 100%);
        border-radius: 3px;
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <h1>Welcome to Shariar's Cafe </h1>
        <p class="lead">Your premium coffee and pastry management hub - Organized, Professional, and Delicious!</p>
        <div class="btn-group-custom">
            <a href="@Url.Action("Index", "Product")" class="btn btn-custom btn-custom-primary">Browse Products</a>
            <a href="@Url.Action("Index", "Order")" class="btn btn-custom btn-custom-primary" style="margin-left: 10px;">View Orders</a>
        </div>
    </div>
</div>

<!-- Statistics Section -->
<main class="container">
    <div class="row">
        <div class="col-md-4">
            <div class="stat-card products">
                <div class="stat-label"> Available Products</div>
                <div class="stat-number">0</div>
                <p style="color: #999; margin: 0;">Premium quality items</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card orders">
                <div class="stat-label"> Orders Placed</div>
                <div class="stat-number">0</div>
                <p style="color: #999; margin: 0;">Customer satisfaction first</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card categories">
                <div class="stat-label">Categories</div>
                <div class="stat-number">0</div>
                <p style="color: #999; margin: 0;">Diverse menu options</p>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="feature-section">
        <h2 class="section-title">Why Choose Us?</h2>
        <div class="row">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"></div>
                    <h3>Premium Products</h3>
                    <p>Handpicked coffee beans, fresh pastries, and premium beverages. Every product is selected with care to ensure the best quality for our customers.</p>
                    <a href="@Url.Action("Index", "Product")" class="btn btn-outline-warning" style="margin-top: 15px; color: var(--cafe-brown); border-color: var(--cafe-brown);">Shop Now</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"></div>
                    <h3>Easy Ordering</h3>
                    <p>Simple and intuitive order management system. Place orders quickly, track them in real-time, and receive updates on delivery status instantly.</p>
                    <a href="@Url.Action("Index", "Order")" class="btn btn-outline-warning" style="margin-top: 15px; color: var(--cafe-brown); border-color: var(--cafe-brown);">My Orders</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"></div>
                    <h3>Organized Menu</h3>
                    <p>Well-categorized menu with detailed descriptions. Find exactly what you're looking for with our smart categorization system.</p>
                    <a href="@Url.Action("Index", "ProductCategory")" class="btn btn-outline-warning" style="margin-top: 15px; color: var(--cafe-brown); border-color: var(--cafe-brown);">Categories</a>
                </div>
            </div>
        </div>
    </div>
</main>